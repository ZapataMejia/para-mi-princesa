---
interface Props {
  size?: number;
  animated?: boolean;
  class?: string;
}

const { size = 64, animated = true, class: className = "" } = Astro.props;
---

<svg
  xmlns="http://www.w3.org/2000/svg"
  viewBox="0 0 64 64"
  width={size}
  height={size}
  class={`inline-block ${animated ? "animate-crown" : ""} ${className}`}
  aria-hidden="true"
  fill="none"
>
  <defs>
    <linearGradient id={`crown-grad-${size}`} x1="0" y1="0" x2="0" y2="1">
      <stop offset="0%" stop-color="#fde58a" />
      <stop offset="55%" stop-color="#f4c95d" />
      <stop offset="100%" stop-color="#d9a83e" />
    </linearGradient>
  </defs>
  <path
    d="M8 22 L18 38 L24 22 L32 40 L40 22 L46 38 L56 22 L52 50 L12 50 Z"
    fill={`url(#crown-grad-${size})`}
    stroke="#a06b1f"
    stroke-width="2"
    stroke-linejoin="round"
  ></path>
  <circle cx="8" cy="22" r="4" fill="#ff6fa1" stroke="#a06b1f" stroke-width="1.5"></circle>
  <circle cx="32" cy="14" r="4.5" fill="#ff6fa1" stroke="#a06b1f" stroke-width="1.5"></circle>
  <circle cx="56" cy="22" r="4" fill="#ff6fa1" stroke="#a06b1f" stroke-width="1.5"></circle>
  <rect x="10" y="48" width="44" height="6" rx="2" fill="#d9a83e" stroke="#a06b1f" stroke-width="1.5"></rect>
  <circle cx="20" cy="51" r="1.5" fill="#fff"></circle>
  <circle cx="32" cy="51" r="1.5" fill="#fff"></circle>
  <circle cx="44" cy="51" r="1.5" fill="#fff"></circle>
</svg>
