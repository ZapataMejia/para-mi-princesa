---
type DoodleType =
  | "heart"
  | "heart-trio"
  | "balloon"
  | "cake"
  | "star"
  | "sparkle"
  | "princess"
  | "ribbon"
  | "scribble";

interface Props {
  type: DoodleType;
  size?: number;
  class?: string;
  rotate?: number;
  color?: string;
}

const { type, size = 48, class: className = "", rotate = 0, color = "#e63946" } = Astro.props;

const style = rotate ? `transform: rotate(${rotate}deg);` : "";
---

{
  type === "heart" && (
    <svg
      viewBox="0 0 64 64"
      width={size}
      height={size}
      class={className}
      style={style}
      aria-hidden="true"
    >
      <path
        d="M32 56 C12 42 6 30 8 22 C10 12 22 8 28 14 C30 16 31 18 32 22 C33 18 34 16 36 14 C42 8 54 12 56 22 C58 30 52 42 32 56 Z"
        fill={color}
        stroke="#a30b1f"
        stroke-width="1.5"
        stroke-linejoin="round"
      />
      <path d="M22 22 C25 19 28 19 30 22" stroke="#fff" stroke-width="2" fill="none" stroke-linecap="round" />
    </svg>
  )
}

{
  type === "heart-trio" && (
    <svg viewBox="0 0 160 110" width={size} height={(size * 110) / 160} class={className} style={style} aria-hidden="true">
      <path
        d="M30 60 C12 46 6 34 10 26 C14 16 28 14 33 21 C34 16 38 14 42 14 C50 14 56 22 54 30 C52 42 42 52 30 60 Z"
        fill={color}
        stroke="#a30b1f"
        stroke-width="1.5"
        stroke-linejoin="round"
      />
      <path
        d="M100 50 C82 36 76 24 80 16 C84 6 98 4 103 11 C104 6 108 4 112 4 C120 4 126 12 124 20 C122 32 112 42 100 50 Z"
        fill={color}
        stroke="#a30b1f"
        stroke-width="1.5"
        stroke-linejoin="round"
      />
      <path
        d="M88 100 C72 86 66 76 70 68 C74 58 88 56 93 63 C94 58 98 56 102 56 C110 56 116 64 114 72 C112 84 102 92 88 100 Z"
        fill={color}
        stroke="#a30b1f"
        stroke-width="1.5"
        stroke-linejoin="round"
      />
    </svg>
  )
}

{
  type === "balloon" && (
    <svg viewBox="0 0 64 96" width={size} height={(size * 96) / 64} class={className} style={style} aria-hidden="true">
      <ellipse cx="32" cy="28" rx="20" ry="24" fill="#ffb6ce" stroke="#d94f7c" stroke-width="2" />
      <path d="M32 12 C26 18 26 26 30 30" stroke="#fff" stroke-width="2" fill="none" stroke-linecap="round" opacity="0.7" />
      <polygon points="30,52 34,52 32,56" fill="#d94f7c" />
      <path
        d="M32 56 C28 60 36 64 32 70 C28 76 36 80 32 84 C28 88 36 92 32 94"
        stroke="#7a3a55"
        stroke-width="1.5"
        fill="none"
        stroke-linecap="round"
      />
    </svg>
  )
}

{
  type === "cake" && (
    <svg viewBox="0 0 64 64" width={size} height={size} class={className} style={style} aria-hidden="true">
      <path d="M32 8 L32 18" stroke="#7a3a55" stroke-width="2" stroke-linecap="round" />
      <path d="M32 12 C30 14 30 16 32 18 C34 16 34 14 32 12 Z" fill="#ffd166" stroke="#a06b1f" stroke-width="1" />
      <rect x="14" y="22" width="36" height="14" rx="2" fill="#ffe4ec" stroke="#7a3a55" stroke-width="1.5" />
      <path d="M14 28 Q22 22 32 28 T50 28" stroke="#d94f7c" stroke-width="1.5" fill="none" />
      <rect x="10" y="36" width="44" height="18" rx="3" fill="#fff5d6" stroke="#7a3a55" stroke-width="1.5" />
      <path d="M10 42 Q20 34 32 42 T54 42" stroke="#f4c95d" stroke-width="1.5" fill="none" />
      <circle cx="20" cy="48" r="2" fill="#ff6fa1" />
      <circle cx="32" cy="48" r="2" fill="#d94f7c" />
      <circle cx="44" cy="48" r="2" fill="#f4c95d" />
    </svg>
  )
}

{
  type === "star" && (
    <svg viewBox="0 0 24 24" width={size} height={size} class={className} style={style} aria-hidden="true">
      <path
        d="M12 2 L14 9 L21 10 L16 14 L18 21 L12 17 L6 21 L8 14 L3 10 L10 9 Z"
        fill="#f4c95d"
        stroke="#a06b1f"
        stroke-width="1"
        stroke-linejoin="round"
      />
    </svg>
  )
}

{
  type === "sparkle" && (
    <svg viewBox="0 0 24 24" width={size} height={size} class={className} style={style} aria-hidden="true">
      <path d="M12 0 L13 10 L24 12 L13 14 L12 24 L11 14 L0 12 L11 10 Z" fill="#ff8fb1" />
    </svg>
  )
}

{
  type === "ribbon" && (
    <svg viewBox="0 0 64 32" width={size} height={(size * 32) / 64} class={className} style={style} aria-hidden="true">
      <path
        d="M2 16 C8 4 22 4 30 14 C36 4 50 4 56 16 C50 22 44 18 36 14 C40 22 32 28 30 22 C28 28 24 22 28 14 C20 18 14 22 8 16 Z"
        fill="#ff6fa1"
        stroke="#a30b3f"
        stroke-width="1.2"
        stroke-linejoin="round"
      />
      <circle cx="32" cy="18" r="3" fill="#fff" stroke="#a30b3f" stroke-width="1" />
    </svg>
  )
}

{
  type === "scribble" && (
    <svg viewBox="0 0 120 30" width={size} height={(size * 30) / 120} class={className} style={style} aria-hidden="true">
      <path
        d="M2 18 Q14 6 26 18 T50 18 T74 18 T98 18 T118 18"
        stroke={color}
        stroke-width="2"
        fill="none"
        stroke-linecap="round"
      />
    </svg>
  )
}

{
  type === "princess" && (
    <svg viewBox="0 0 140 180" width={size} height={(size * 180) / 140} class={className} style={style} aria-hidden="true">
      <path
        d="M40 36 L52 22 L60 32 L70 18 L80 32 L88 22 L100 36 Z"
        fill="#f4c95d"
        stroke="#a06b1f"
        stroke-width="2"
        stroke-linejoin="round"
      />
      <circle cx="60" cy="24" r="3" fill="#ff6fa1" stroke="#a06b1f" stroke-width="1" />
      <circle cx="70" cy="14" r="3" fill="#ff6fa1" stroke="#a06b1f" stroke-width="1" />
      <circle cx="80" cy="24" r="3" fill="#ff6fa1" stroke="#a06b1f" stroke-width="1" />

      <circle cx="70" cy="60" r="28" fill="#fff5e6" stroke="#2c2330" stroke-width="2" />
      <circle cx="60" cy="58" r="2" fill="#2c2330" />
      <circle cx="80" cy="58" r="2" fill="#2c2330" />
      <path d="M62 70 Q70 76 78 70" stroke="#2c2330" stroke-width="1.8" fill="none" stroke-linecap="round" />
      <circle cx="56" cy="66" r="3" fill="#ffb6ce" opacity="0.7" />
      <circle cx="84" cy="66" r="3" fill="#ffb6ce" opacity="0.7" />

      <line x1="70" y1="88" x2="70" y2="140" stroke="#2c2330" stroke-width="2" stroke-linecap="round" />
      <line x1="70" y1="100" x2="40" y2="80" stroke="#2c2330" stroke-width="2" stroke-linecap="round" />
      <line x1="70" y1="100" x2="105" y2="115" stroke="#2c2330" stroke-width="2" stroke-linecap="round" />
      <line x1="70" y1="140" x2="55" y2="170" stroke="#2c2330" stroke-width="2" stroke-linecap="round" />
      <line x1="70" y1="140" x2="86" y2="170" stroke="#2c2330" stroke-width="2" stroke-linecap="round" />

      <ellipse cx="32" cy="62" rx="14" ry="18" fill="#ffb6ce" stroke="#d94f7c" stroke-width="1.6" />
      <path d="M40 80 Q34 84 36 90 Q32 92 38 95" stroke="#7a3a55" stroke-width="1.4" fill="none" stroke-linecap="round" />

      <rect x="100" y="100" width="22" height="14" rx="2" fill="#fff5d6" stroke="#7a3a55" stroke-width="1.4" />
      <rect x="98" y="96" width="26" height="6" rx="1.5" fill="#ffe4ec" stroke="#7a3a55" stroke-width="1.4" />
      <line x1="111" y1="92" x2="111" y2="96" stroke="#7a3a55" stroke-width="1.4" stroke-linecap="round" />
      <path d="M111 86 Q108 90 111 92 Q114 90 111 86 Z" fill="#ffd166" stroke="#a06b1f" stroke-width="0.8" />

      <path d="M92 60 L100 56 M96 64 L102 70" stroke="#e63946" stroke-width="2" stroke-linecap="round" fill="none" />
    </svg>
  )
}
