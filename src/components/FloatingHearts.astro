---
const HEARTS = 18;
const items = Array.from({ length: HEARTS }, (_, i) => {
  const left = Math.round((i / HEARTS) * 100 + Math.random() * 6);
  const size = 14 + Math.random() * 22;
  const delay = (Math.random() * 16).toFixed(2);
  const duration = (12 + Math.random() * 16).toFixed(2);
  const variant = i % 4;
  return { left, size, delay, duration, variant };
});
---

<div class="floating-hearts pointer-events-none fixed inset-0 -z-10 overflow-hidden" aria-hidden="true">
  {
    items.map((h) => (
      <span
        class="floating-heart absolute bottom-0 animate-float-up"
        style={`left:${h.left}%; width:${h.size}px; height:${h.size}px; animation-delay:${h.delay}s; animation-duration:${h.duration}s;`}
      >
        {h.variant === 0 && (
          <svg viewBox="0 0 24 24" fill="#ff8fb1" fill-opacity="0.65">
            <path d="M12 21s-7.5-4.5-9.5-9.5C1 7.6 4 4 8 4c2 0 3.5 1 4 2.5C12.5 5 14 4 16 4c4 0 7 3.6 5.5 7.5C19.5 16.5 12 21 12 21z" />
          </svg>
        )}
        {h.variant === 1 && (
          <svg viewBox="0 0 24 24" fill="#e8d5f2" fill-opacity="0.85">
            <path d="M12 21s-7.5-4.5-9.5-9.5C1 7.6 4 4 8 4c2 0 3.5 1 4 2.5C12.5 5 14 4 16 4c4 0 7 3.6 5.5 7.5C19.5 16.5 12 21 12 21z" />
          </svg>
        )}
        {h.variant === 2 && (
          <svg viewBox="0 0 24 24" fill="#f4c95d" fill-opacity="0.85">
            <path d="M12 2l2.39 4.84 5.34.78-3.86 3.77.91 5.31L12 14.77l-4.78 2.51.91-5.31L4.27 7.62l5.34-.78L12 2z" />
          </svg>
        )}
        {h.variant === 3 && (
          <svg viewBox="0 0 24 24" fill="#ff6fa1" fill-opacity="0.5">
            <path d="M12 21s-7.5-4.5-9.5-9.5C1 7.6 4 4 8 4c2 0 3.5 1 4 2.5C12.5 5 14 4 16 4c4 0 7 3.6 5.5 7.5C19.5 16.5 12 21 12 21z" />
          </svg>
        )}
      </span>
    ))
  }
</div>

<style>
  .floating-heart svg {
    width: 100%;
    height: 100%;
    filter: drop-shadow(0 4px 6px rgba(255, 111, 161, 0.25));
  }
</style>
