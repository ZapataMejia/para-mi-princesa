---
import type { Letter } from "../data/letters";

interface Props {
  letter: Letter;
}

const { letter } = Astro.props;

const monthNames = [
  "ene", "feb", "mar", "abr", "may", "jun",
  "jul", "ago", "sep", "oct", "nov", "dic",
];
const [yyyy, mm, dd] = letter.date.split("-").map(Number);
const monthLabel = monthNames[(mm ?? 1) - 1];
const dayLabel = String(dd).padStart(2, "0");
---

<a
  class="letter-card group relative flex aspect-[4/5] flex-col items-center justify-between overflow-hidden rounded-3xl p-5 text-center transition-transform duration-300 will-change-transform princess-card princess-card--locked"
  href={`/cartas/${letter.slug}`}
  data-date={letter.date}
  data-slug={letter.slug}
  data-day={letter.day}
  data-birthday={letter.isBirthday ? "true" : "false"}
  aria-label={`Carta del día ${letter.day}: ${letter.title}`}
>
  <span class="card-corner-tl pointer-events-none absolute -top-3 -left-3 h-10 w-10 rounded-full bg-[#f4c95d]/30 blur-xl"></span>
  <span class="card-corner-br pointer-events-none absolute -bottom-3 -right-3 h-10 w-10 rounded-full bg-[#ff8fb1]/40 blur-xl"></span>

  <header class="flex w-full items-center justify-between text-[#a0567a]">
    <span class="rounded-full bg-white/70 px-2 py-0.5 text-[11px] font-semibold uppercase tracking-[0.18em]">
      día {letter.day}
    </span>
    <span class="text-[11px] font-semibold uppercase tracking-[0.18em]">
      {dayLabel} {monthLabel}
    </span>
  </header>

  <div class="state-locked flex flex-1 flex-col items-center justify-center gap-2">
    <svg viewBox="0 0 64 64" class="h-14 w-14 text-[#d9a83e] drop-shadow-sm" fill="currentColor" aria-hidden="true">
      <path d="M20 28V20a12 12 0 0 1 24 0v8h2a4 4 0 0 1 4 4v22a4 4 0 0 1-4 4H18a4 4 0 0 1-4-4V32a4 4 0 0 1 4-4h2zm4 0h16v-8a8 8 0 1 0-16 0v8z"/>
      <circle cx="32" cy="44" r="3.5" fill="#fff"/>
      <rect x="30.5" y="44" width="3" height="8" fill="#fff" rx="1"/>
    </svg>
    <p class="text-fairy text-2xl text-[#d94f7c]">Aún no, Pollito</p>
    <p class="countdown-text text-xs uppercase tracking-[0.14em] text-[#a0567a]/80">
      Faltan <span data-fallback>--</span> días
    </p>
  </div>

  <div class="state-today hidden flex-1 flex-col items-center justify-center gap-2">
    <div class="envelope-open relative">
      <svg viewBox="0 0 64 48" class="h-16 w-20" aria-hidden="true">
        <rect x="2" y="10" width="60" height="34" rx="4" fill="#fff" stroke="#d94f7c" stroke-width="1.5"/>
        <path d="M2 14 L32 32 L62 14" fill="none" stroke="#d94f7c" stroke-width="1.5"/>
        <path d="M22 22 L32 14 L42 22 L42 30 L22 30 Z" fill="#ff6fa1"/>
        <path d="M30 22c0-1.5 1-2.5 2.3-2.5 1.4 0 2.2 1 2.2 2.3 0 2-2.3 3.7-2.3 3.7s-2.2-1.7-2.2-3.5z" fill="#fff"/>
      </svg>
    </div>
    <p class="text-fairy text-2xl text-[#d94f7c]">¡Para ti, hoy!</p>
    <p class="text-xs font-semibold uppercase tracking-[0.18em] text-[#d94f7c]">Ábreme</p>
  </div>

  <div class="state-past hidden flex-1 flex-col items-center justify-center gap-2">
    <span class="text-4xl">{letter.emoji}</span>
    <p class="text-script text-xl text-[#d94f7c]">{letter.title}</p>
    <p class="text-[11px] uppercase tracking-[0.18em] text-[#a0567a]/80">Léeme de nuevo</p>
  </div>

  <footer class="mt-2 line-clamp-2 w-full text-xs text-[#6b3a52]/70">
    <span class="locked-preview">Una sorpresita guardada para ti</span>
    <span class="open-preview hidden">{letter.preview}</span>
  </footer>
</a>

<style>
  .letter-card.is-today {
    animation: shine 2.4s ease-in-out infinite;
    background: linear-gradient(180deg, #fffafd 0%, #ffe4ec 100%);
    border: 1.5px solid rgba(244, 201, 93, 0.85);
  }
  .letter-card.is-past {
    background: linear-gradient(180deg, #fffafd 0%, #ffe4ec 100%);
    border: 1px solid rgba(244, 201, 93, 0.45);
    box-shadow: 0 10px 30px -8px rgba(255, 111, 161, 0.3);
  }
  .letter-card.is-locked .state-today,
  .letter-card.is-locked .state-past,
  .letter-card.is-locked .open-preview {
    display: none !important;
  }
  .letter-card.is-today .state-locked,
  .letter-card.is-today .state-past,
  .letter-card.is-today .locked-preview {
    display: none !important;
  }
  .letter-card.is-past .state-locked,
  .letter-card.is-past .state-today,
  .letter-card.is-past .locked-preview {
    display: none !important;
  }
  .letter-card.is-today .state-today,
  .letter-card.is-past .state-past {
    display: flex !important;
  }
  .letter-card.is-today .open-preview,
  .letter-card.is-past .open-preview {
    display: inline !important;
  }
  .letter-card:not(.is-locked):hover {
    transform: translateY(-4px) scale(1.02);
  }
  .letter-card.is-shaking {
    animation: wiggle 0.6s ease-in-out;
  }
</style>
