---
interface Props {
  count?: number;
}

const { count = 12 } = Astro.props;

const items = Array.from({ length: count }, (_, i) => ({
  top: Math.round(Math.random() * 92) + 2,
  left: Math.round(Math.random() * 92) + 2,
  size: 8 + Math.random() * 12,
  delay: (Math.random() * 3).toFixed(2),
  duration: (2 + Math.random() * 2).toFixed(2),
  hue: i % 2 === 0 ? "#f4c95d" : "#ff8fb1",
}));
---

<div class="pointer-events-none absolute inset-0 overflow-hidden" aria-hidden="true">
  {
    items.map((s) => (
      <svg
        viewBox="0 0 24 24"
        class="absolute animate-sparkle"
        style={`top:${s.top}%; left:${s.left}%; width:${s.size}px; height:${s.size}px; animation-delay:${s.delay}s; animation-duration:${s.duration}s;`}
        fill={s.hue}
      >
        <path d="M12 0 L14 10 L24 12 L14 14 L12 24 L10 14 L0 12 L10 10 Z" />
      </svg>
    ))
  }
</div>
