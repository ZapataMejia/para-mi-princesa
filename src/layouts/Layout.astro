---
import "../styles/global.css";
import FloatingHearts from "../components/FloatingHearts.astro";

interface Props {
  title?: string;
  description?: string;
  showHearts?: boolean;
}

const {
  title = "Para mi princesa Esmeralda",
  description = "Una cuenta regresiva llena de cartas para Pollito",
  showHearts = true,
} = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#ffb6ce" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Caveat:wght@400;500;600;700&family=Caveat+Brush&family=Great+Vibes&family=Kalam:wght@300;400;700&family=Pacifico&family=Quicksand:wght@400;500;600;700&family=Sacramento&display=swap"
    />
    <title>{title}</title>
  </head>
  <body class="relative">
    {showHearts && <FloatingHearts />}
    <slot />
  </body>
</html>
