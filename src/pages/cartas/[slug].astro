---
import Layout from "../../layouts/Layout.astro";
import Doodle from "../../components/Doodle.astro";
import Confetti from "../../components/Confetti.astro";
import {
  letters,
  FIRMA,
  APODO,
  daysUntilBirthday,
  parseHighlights,
} from "../../data/letters";

export async function getStaticPaths() {
  return letters.map((letter) => ({
    params: { slug: letter.slug },
    props: { letter },
  }));
}

const { letter } = Astro.props;

const monthNames = [
  "enero", "febrero", "marzo", "abril", "mayo", "junio",
  "julio", "agosto", "septiembre", "octubre", "noviembre", "diciembre",
];
const [yyyy, mm, dd] = letter.date.split("-").map(Number);
const fechaLarga = `${dd} de ${monthNames[(mm ?? 1) - 1]} de ${yyyy}`;

const diasRestantes = daysUntilBirthday(letter.date);

let unlockHora = "";
if (letter.unlockAt) {
  const dt = new Date(letter.unlockAt);
  const h = dt.getHours();
  const m = String(dt.getMinutes()).padStart(2, "0");
  const ampm = h >= 12 ? "pm" : "am";
  const h12 = h % 12 === 0 ? 12 : h % 12;
  unlockHora = `${h12}:${m} ${ampm}`;
}
---

<Layout title={`${letter.title} · Día ${letter.day}`} description={letter.preview}>
  <div
    class="letter-page relative mx-auto flex min-h-[100dvh] w-full max-w-3xl flex-col items-center justify-center px-5 py-8 sm:py-14"
    data-date={letter.date}
    data-unlock-at={letter.unlockAt}
    data-birthday={letter.isBirthday ? "true" : "false"}
    data-surprise={letter.isSurprise ? "true" : "false"}
  >
    {/* PANTALLA BLOQUEADA */}
    <div class="locked-screen hidden w-full">
      <article class="paper paper--no-tape relative mx-auto w-full max-w-2xl px-7 py-10 text-center sm:px-12 sm:py-14">
        <div class="absolute -top-4 left-6 -rotate-6">
          <Doodle type="heart-trio" size={70} class="opacity-70" />
        </div>
        <div class="relative z-10 flex flex-col items-center gap-4">
          <Doodle type={letter.isSurprise ? "balloon" : "cake"} size={80} class="doodle-wobble" />
          <h1 class="title-marker">Aún no, {APODO}</h1>
          <p class="handwritten max-w-md">
            {letter.unlockAt ? (
              <>Esta sorpresita se desbloquea hoy a las <span class="highlight">{unlockHora}</span>. Faltan poquito, mi amor.</>
            ) : (
              <>Esta cartita se desbloquea el <span class="highlight">{fechaLarga}</span>. Sé paciente, mi amor, vale la pena la espera.</>
            )}
          </p>
          <p class="countdown-line mt-1" data-locked-line>
            Faltan <span class="countdown-pill" data-locked-days>--</span> {letter.unlockAt ? "" : "días"} para abrirla
          </p>
          <a
            href="/"
            class="mt-4 inline-flex items-center gap-2 rounded-full bg-[#ff6fa1] px-5 py-2 text-sm font-semibold uppercase tracking-[0.18em] text-white shadow-md transition hover:scale-105"
          >
            Volver al inicio
          </a>
        </div>
      </article>
    </div>

    {/* PANTALLA DESBLOQUEADA */}
    <div class="open-screen hidden w-full">
      {letter.isBirthday && <Confetti />}

      <article
        class:list={[
          "paper relative mx-auto w-full max-w-2xl px-6 py-12 sm:px-12 sm:py-16",
          letter.isBirthday ? "paper--birthday" : "",
        ]}
      >
        {/* esquinas decorativas */}
        <div class="pointer-events-none absolute right-4 top-2 sm:right-8 sm:top-4">
          <Doodle type="heart-trio" size={110} class="opacity-95" />
        </div>
        <div class="pointer-events-none absolute -left-2 top-32 hidden sm:block">
          <Doodle type="scribble" size={110} color="#ff8fb1" rotate={-8} />
        </div>
        <div class="pointer-events-none absolute -right-2 bottom-44 hidden sm:block">
          <Doodle type="star" size={32} class="doodle-wobble" rotate={12} />
        </div>
        <div class="pointer-events-none absolute -left-3 bottom-36 hidden sm:block">
          <Doodle type="ribbon" size={70} rotate={-12} />
        </div>

        {/* saludo big */}
        <header class="relative z-10 mb-6">
          <h1 class="title-marker inline-block">
            <span set:html={parseHighlights(letter.greeting)} />
          </h1>
          <div class="mt-4">
            <span class="pet-names" set:html={parseHighlights(letter.petNames)} />
          </div>
          <p class="handwritten mt-4 text-[#2c2330]">
            <span set:html={parseHighlights(letter.opener)} />
          </p>
        </header>

        {/* margen note */}
        {letter.marginNote && (
          <aside class="relative z-10 mb-6 flex justify-end sm:absolute sm:right-6 sm:top-44 sm:mb-0 sm:max-w-[180px]">
            <span class="margin-note" set:html={letter.marginNote} />
          </aside>
        )}

        {/* cuerpo */}
        <div class="handwritten relative z-10 mt-2 space-y-2 sm:max-w-[80%]">
          {letter.body.map((paragraph) => (
            <p set:html={parseHighlights(paragraph)} />
          ))}
        </div>

        {letter.image && (
          <figure class="blur-reveal relative z-10 mx-auto mt-8 flex max-w-md flex-col items-center gap-3">
            <div
              class="blur-frame relative w-full overflow-hidden rounded-2xl"
              data-blur={letter.image.blur ?? 36}
            >
              <img
                src={letter.image.src}
                alt={letter.image.alt}
                class="blur-img block w-full"
                style={`filter: blur(${letter.image.blur ?? 36}px); transform: scale(1.08);`}
                draggable={false}
              />
              <div class="pointer-events-none absolute inset-0 bg-gradient-to-br from-[#ff8fb1]/20 via-transparent to-[#f4c95d]/20"></div>
              <span class="pointer-events-none absolute right-3 top-3 rounded-full bg-[#d94f7c]/90 px-3 py-1 text-[11px] font-semibold uppercase tracking-[0.18em] text-white shadow">
                Pista
              </span>
            </div>
            {letter.image.caption && (
              <figcaption class="text-hand text-lg text-[#7a3a55]" set:html={parseHighlights(letter.image.caption)} />
            )}
          </figure>
        )}

        {/* countdown line */}
        <div class="relative z-10 mt-8 flex flex-wrap items-center gap-3">
          <p class="countdown-line">
            {!letter.isBirthday && (
              <>
                Solamente faltan{" "}
                <span class="countdown-pill">{diasRestantes}</span>{" "}
                {diasRestantes === 1 ? "día" : "días"} para tu cumple!!
              </>
            )}
            {letter.isBirthday && (
              <span class="title-marker text-[#d94f7c]">¡Hoy es tu cumple, mi vida!!</span>
            )}
          </p>
          {!letter.isBirthday && <Doodle type="balloon" size={56} class="doodle-wobble" rotate={-6} />}
          {letter.isBirthday && <Doodle type="cake" size={70} class="doodle-wobble" />}
        </div>

        {/* cierre */}
        <div class="relative z-10 mt-8 space-y-2">
          <p class="handwritten" set:html={parseHighlights(letter.closing)} />
          <p class="handwritten font-semibold text-[#2c2330]" set:html={parseHighlights(letter.signoffLine)} />
        </div>

        {letter.clue && (
          <div class="relative z-10 mt-8 border-t border-dashed border-[#d94f7c]/40 pt-4">
            <p class="text-hand text-lg text-[#7a3a55] sm:text-xl" set:html={parseHighlights(letter.clue)} />
          </div>
        )}

        {/* firma */}
        <footer class="relative z-10 mt-10 flex items-end justify-between">
          <Doodle type="princess" size={120} class="opacity-95" />
          <div class="text-right">
            <p class="signature">{FIRMA}</p>
            <p class="text-hand text-sm text-[#7a3a55]">{fechaLarga}</p>
          </div>
        </footer>
      </article>

      <nav class="mt-8 flex w-full items-center justify-between">
        <a
          href="/"
          class="inline-flex items-center gap-2 rounded-full bg-white/85 px-4 py-2 text-xs font-semibold uppercase tracking-[0.18em] text-[#d94f7c] shadow-sm transition hover:scale-105"
        >
          ← Todas las cartas
        </a>
        <p class="text-hand text-xl text-[#7a3a55]">Te amo, {APODO}.</p>
      </nav>
    </div>
  </div>
</Layout>

<style>
  .paper--birthday {
    background-color: #fff8f0;
    background-image:
      radial-gradient(circle at 20% 20%, rgba(244, 201, 93, 0.18) 0, transparent 40%),
      radial-gradient(circle at 80% 80%, rgba(255, 143, 177, 0.18) 0, transparent 45%),
      repeating-linear-gradient(
        to bottom,
        transparent 0,
        transparent 35px,
        rgba(217, 192, 222, 0.28) 35px,
        rgba(217, 192, 222, 0.28) 36px
      );
    box-shadow:
      0 0 0 2px rgba(244, 201, 93, 0.45),
      0 22px 50px -12px rgba(80, 30, 60, 0.4),
      0 0 60px -10px rgba(244, 201, 93, 0.45);
  }
</style>

<script>
  function todayKey(): string {
    const now = new Date();
    const yyyy = now.getFullYear();
    const mm = String(now.getMonth() + 1).padStart(2, "0");
    const dd = String(now.getDate()).padStart(2, "0");
    return `${yyyy}-${mm}-${dd}`;
  }

  function diffDays(targetIsoDate: string): number {
    const [y, m, d] = targetIsoDate.split("-").map(Number);
    const target = new Date(y!, (m ?? 1) - 1, d ?? 1);
    const now = new Date();
    const today = new Date(now.getFullYear(), now.getMonth(), now.getDate());
    return Math.round(
      (target.getTime() - today.getTime()) / (1000 * 60 * 60 * 24)
    );
  }

  function isPreview(): boolean {
    try {
      const params = new URLSearchParams(window.location.search);
      return (
        params.get("p") === "1" ||
        params.get("preview") === "1" ||
        params.get("santi") === "1"
      );
    } catch {
      return false;
    }
  }

  function fmtCountdown(remainingMs: number): { value: string; unit: string } {
    if (remainingMs <= 0) return { value: "0", unit: "" };
    const totalSeconds = Math.floor(remainingMs / 1000);
    const hours = Math.floor(totalSeconds / 3600);
    const mins = Math.floor((totalSeconds % 3600) / 60);
    const secs = totalSeconds % 60;
    if (hours >= 1) {
      return { value: `${hours}h ${mins}m`, unit: "" };
    }
    if (mins >= 1) {
      return { value: `${mins}m ${String(secs).padStart(2, "0")}s`, unit: "" };
    }
    return { value: `${secs}s`, unit: "" };
  }

  let timer: number | null = null;

  function render(root: HTMLElement): void {
    const date = root.getAttribute("data-date");
    const unlockAt = root.getAttribute("data-unlock-at");
    if (!date) return;

    const today = todayKey();
    const locked = root.querySelector<HTMLElement>(".locked-screen");
    const open = root.querySelector<HTMLElement>(".open-screen");
    if (!locked || !open) return;

    const preview = isPreview();
    let isOpen = false;

    if (unlockAt) {
      const unlockMs = new Date(unlockAt).getTime();
      isOpen = preview || Date.now() >= unlockMs;

      if (!isOpen) {
        const daysSpan = locked.querySelector<HTMLElement>("[data-locked-days]");
        if (daysSpan) {
          const { value } = fmtCountdown(unlockMs - Date.now());
          daysSpan.textContent = value;
        }
        const lockLine = locked.querySelector<HTMLElement>("[data-locked-line]");
        if (lockLine) {
          lockLine.innerHTML =
            'Faltan <span class="countdown-pill" data-locked-days>' +
            (locked.querySelector<HTMLElement>("[data-locked-days]")?.textContent ?? "--") +
            "</span> para abrirla";
        }
      }
    } else {
      isOpen = preview || date <= today;
      if (!isOpen) {
        const daysSpan = locked.querySelector<HTMLElement>("[data-locked-days]");
        if (daysSpan) {
          daysSpan.textContent = String(diffDays(date));
        }
      }
    }

    if (isOpen) {
      open.classList.remove("hidden");
      locked.classList.add("hidden");
      if (timer) {
        clearInterval(timer);
        timer = null;
      }
    } else {
      locked.classList.remove("hidden");
      open.classList.add("hidden");
    }

    if (preview && !document.querySelector("[data-preview-banner]")) {
      const banner = document.createElement("div");
      banner.dataset.previewBanner = "1";
      banner.textContent = "MODO PREVIEW (solo tú la ves)";
      banner.style.cssText =
        "position:fixed;top:10px;left:50%;transform:translateX(-50%);background:#d94f7c;color:#fff;padding:6px 14px;border-radius:999px;font-family:system-ui,sans-serif;font-size:12px;letter-spacing:0.16em;text-transform:uppercase;z-index:50;box-shadow:0 6px 18px -4px rgba(217,79,124,0.5);";
      document.body.appendChild(banner);
    }
  }

  function init(): void {
    const root = document.querySelector<HTMLElement>(".letter-page");
    if (!root) return;
    render(root);
    if (root.getAttribute("data-unlock-at")) {
      timer = window.setInterval(() => render(root), 1000);
    }
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", init);
  } else {
    init();
  }
</script>
